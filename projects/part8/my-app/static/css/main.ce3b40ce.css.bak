:root{--espresso:#2c1810;--coffee-dark:#4a3428;--latte:#d4a574;--cream:#f5f1e8;--accent:#c17c4a;--bronze:#cd7f32;--silver:silver;--gold:gold}*{box-sizing:border-box;margin:0;padding:0}body{background:#f5f1e8;background:var(--cream);color:#2c1810;color:var(--espresso);font-family:Lora,serif;line-height:1.6;overflow-x:hidden}header{background:linear-gradient(135deg,#2c1810,#4a3428);background:linear-gradient(135deg,var(--espresso) 0,var(--coffee-dark) 100%);box-shadow:0 4px 20px #00000026;padding:1rem 2rem;position:sticky;top:0;z-index:100}.logo,nav a{color:#f5f1e8}nav a:after{background:#d4a574}.hero{background:linear-gradient(165deg,#4a3428,#2c1810 50%,#1a0f0a);background:linear-gradient(165deg,var(--coffee-dark) 0,var(--espresso) 50%,#1a0f0a 100%);color:#f5f1e8;color:var(--cream);overflow:hidden;padding:8rem 2rem 6rem;position:relative}.hero:before{animation:float 20s ease-in-out infinite;background:radial-gradient(circle,#d4a5741a 0,#0000 70%);content:"";height:200%;position:absolute;right:-20%;top:-50%;width:80%}@keyframes float{0%,to{transform:translate(0) rotate(0deg)}50%{transform:translate(-50px,50px) rotate(5deg)}}.hero-content{margin:0 auto;max-width:1400px;position:relative;text-align:center;z-index:2}h1{font-family:Playfair Display,serif;font-size:4.5rem;font-weight:900;letter-spacing:-2px;line-height:1.1;margin-bottom:1.5rem}.hero.animate h1{animation:fadeInUp 1s ease-out}.splash_0{background-image:url(/projects/part/8/my-app/static/media/splash_0.255793186e0c15015166.jpg)}.splash_1{background-image:url(/projects/part/8/my-app/static/media/splash_1.71ffe1d650953968443c.jpg)}.splash_2{background-image:url(/projects/part/8/my-app/static/media/splash_2.5e616b0758d7477927f7.jpg)}@keyframes fadeInUp{0%{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}.hero p{font-size:1.3rem;margin-bottom:2.5rem;opacity:.95}.hero.animate p{animation:fadeInUp 1s ease-out .2s both}.hero.hero-simple{background:linear-gradient(135deg,#4a3428,#2c1810);background:linear-gradient(135deg,var(--coffee-dark),var(--espresso));padding:5rem 2rem;text-align:center}.hero.hero-simple h1{animation:none;font-size:3.5rem}.hero.hero-simple p{animation:none}.hero.hero-accent{background:linear-gradient(135deg,#d4a574,#c17c4a);background:linear-gradient(135deg,var(--latte) 0,var(--accent) 100%);color:#2c1810;color:var(--espresso)}.cta-buttons{animation:fadeInUp 1s ease-out .4s both;display:flex;gap:1.5rem;justify-content:center}.btn{border:none;border-radius:50px;cursor:pointer;display:inline-block;font-family:Lora,serif;font-size:1rem;font-weight:600;padding:1rem 2.5rem;text-decoration:none;transition:all .3s ease}.btn-primary{background:#d4a574;background:var(--latte);box-shadow:0 4px 20px #d4a57466;color:#2c1810;color:var(--espresso)}.btn-primary:hover{background:#c17c4a;background:var(--accent);box-shadow:0 6px 30px #d4a57499;transform:translateY(-3px)}.btn-secondary{background:#0000;border:2px solid #f5f1e8;border:2px solid var(--cream);color:#f5f1e8;color:var(--cream)}.btn-secondary:hover{background:#f5f1e8;background:var(--cream);color:#2c1810;color:var(--espresso);transform:translateY(-3px)}.btn-primary.btn-dark{background:#2c1810;background:var(--espresso);box-shadow:0 4px 20px #2c18104d;color:#f5f1e8;color:var(--cream)}.btn-primary.btn-dark:hover{box-shadow:0 6px 30px #2c181066;transform:translateY(-3px)}.section-title{color:#2c1810;color:var(--espresso);font-family:Playfair Display,serif;font-size:2.8rem;margin-bottom:3rem;text-align:center}.filter-section{background:#fff;border-bottom:2px solid #f5f1e8;border-bottom:2px solid var(--cream);padding:2rem;top:72px;z-index:50}.filter-container{display:flex;flex-wrap:wrap;gap:1rem;justify-content:center;margin:0 auto;max-width:1400px}.filter-btn{background:#f5f1e8;background:var(--cream);border:2px solid #d4a574;border:2px solid var(--latte);border-radius:50px;color:#2c1810;color:var(--espresso);cursor:pointer;font-family:Lora,serif;font-size:.95rem;font-weight:600;padding:.7rem 1.5rem;transition:all .3s ease}.filter-btn.active,.filter-btn:hover{background:#d4a574;background:var(--latte);color:#2c1810;color:var(--espresso);transform:translateY(-2px)}.benefit-card,.feature-card,.value-card{background:#fff;border-radius:20px;box-shadow:0 10px 40px #2c181014;overflow:hidden;padding:2.5rem;position:relative;transition:all .4s ease}.feature-card:before{background:linear-gradient(90deg,#d4a574,#c17c4a);background:linear-gradient(90deg,var(--latte),var(--accent));content:"";height:4px;left:0;position:absolute;top:0;transform:scaleX(0);transform-origin:left;transition:transform .4s ease;width:100%}.feature-card:hover:before{transform:scaleX(1)}.benefit-card:hover,.feature-card:hover,.value-card:hover{box-shadow:0 20px 60px #2c181026;transform:translateY(-10px)}.benefit-card h3,.feature-card h3,.value-card h3{color:#2c1810;color:var(--espresso);font-family:Playfair Display,serif;font-size:1.8rem;margin-bottom:1rem}.benefit-card p,.feature-card p,.value-card p{color:#4a3428;color:var(--coffee-dark);font-size:1.05rem}.benefit-card{background:#f5f1e8;background:var(--cream);border:2px solid #0000;border-radius:15px;padding:2.5rem;transition:all .3s ease}.benefit-card:hover{border-color:#d4a574;border-color:var(--latte);box-shadow:0 10px 30px #2c18101a;transform:translateY(-5px)}.benefits-grid,.features-grid,.values-grid{grid-gap:3rem;display:grid;gap:3rem;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));margin-top:3rem}.benefits-grid{gap:2.5rem;grid-template-columns:repeat(auto-fit,minmax(280px,1fr))}.features{margin:0 auto;max-width:1400px;padding:6rem 2rem}.signature{align-items:center;background:linear-gradient(135deg,#1a0f0a,#2c1810 50%,#4a3428);background:linear-gradient(135deg,#1a0f0a 0,var(--espresso) 50%,var(--coffee-dark) 100%);color:#f5f1e8;color:var(--cream);display:flex;justify-content:center;margin-bottom:5rem;overflow:hidden;padding:6rem 2rem;position:relative}.signature:after{background:radial-gradient(circle,#d4a57414 0,#0000 